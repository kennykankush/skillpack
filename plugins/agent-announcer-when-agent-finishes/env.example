# Save this as ~/.config/tab-tts/env (mode 600).
# All values are optional. Provider auto mode tries ElevenLabs, then OpenAI,
# then macOS `say`, depending on which keys are present and usable.

# Voice provider. Use "auto", "qwen", "elevenlabs", "openai", or "say".
TAB_TTS_PROVIDER=auto

# Optional fallback after the selected provider fails or runs low on credits.
TAB_TTS_FALLBACK_PROVIDER=auto

# Alias if you prefer the shorter wording:
# VOICE_CHANNEL=elevenlabs

# Local Qwen voicepack provider.
# Requires a qwen_tts Python env and a voicepack with qwen_voice_prompt.pt.
# TAB_TTS_PROVIDER=qwen
TAB_TTS_QWEN_PYTHON="$HOME/dev/voicepack/.venv-qwen/bin/python"
TAB_TTS_QWEN_RUNNER="$HOME/dev/voicepack/runners/qwen/speak.py"
TAB_TTS_QWEN_VOICE="$HOME/dev/voicepack/library/cortana"
# Warm server cache. Enabled by default for TAB_TTS_PROVIDER=qwen.
# First hook after reboot starts it; later hooks reuse it.
TAB_TTS_QWEN_AUTO_SERVER=1
# TAB_TTS_QWEN_SERVER_URL=http://127.0.0.1:8765
# TAB_TTS_QWEN_AUTO_START_TIMEOUT_SEC=60
# TAB_TTS_QWEN_SERVER_TIMEOUT_SEC=30
# TAB_TTS_QWEN_DEVICE=mps
# TAB_TTS_QWEN_DTYPE=float16
# TAB_TTS_QWEN_SEED=16010

# Cloud keys. Set one or both.
# ELEVENLABS_API_KEY=...
# OPENAI_TTS_KEY=sk-proj-...

# ElevenLabs voice settings.
# JBFqnCBsd6RMkjVDRZzb is the docs sample voice id; swap this for your chosen voice.
# hpp4J3VqNfWAUOO0d1Us is Bella, a bright/professional premade female voice.
# sJSpUxhUVjGSYgbo5FeK is a user-generated Cortana/Halo-inspired sci-fi AI companion voice.
# Generated voices may be account-scoped; replace with a voice id visible in your ElevenLabs account if needed.
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Check subscription usage before spending credits. If remaining credits are
# less than phrase length + reserve, the script falls back.
ELEVENLABS_CHECK_CREDITS=1
ELEVENLABS_MIN_REMAINING_CREDITS=200

# OpenAI voice. Female: nova, shimmer, sage, coral. Male: alloy, ash, ballad, echo, fable, onyx, verse.
TAB_TTS_VOICE=nova

# Speech styling (gpt-4o-mini-tts only; respects natural-language tone directions).
TAB_TTS_INSTRUCTIONS="Speak in a warm, soft, slightly playful and intimate tone. Relaxed and unhurried, like a close friend leaning in."

# Mode. "summary" = LLM-generated handover. "number" = just the tab label.
TAB_TTS_MODE=summary

# Optional model overrides.
# TAB_TTS_SUMMARY_MODEL=gpt-4.1-nano
# TAB_TTS_MODEL=gpt-4o-mini-tts

# Summary speech budget.
# auto = qwen/local TTS gets richer summaries; paid cloud TTS stays compact.
# tab = skip the summary call and speak only the tab label.
TAB_TTS_SUMMARY_BUDGET=auto
# TAB_TTS_LOCAL_SUMMARY_WORDS="12-24 words"
# TAB_TTS_LOCAL_SUMMARY_MAX_CHARS=220
# TAB_TTS_LOCAL_SUMMARY_MAX_TOKENS=140
# TAB_TTS_PAID_SUMMARY_WORDS="6-10 words"
# TAB_TTS_PAID_SUMMARY_MAX_CHARS=90
# TAB_TTS_PAID_SUMMARY_MAX_TOKENS=60

# Debug mode. When enabled, /tmp/tab-tts.log gets:
# tts_debug=[MODEL NAME] } TAB } voice source } spoken text }
# TAB_TTS_DEBUG=1
# Also speak that prefix out loud:
# TAB_TTS_DEBUG_SPEAK=1

# Timing dataset. Enabled by default; set to 0/off/false to disable.
TAB_TTS_TIMING=1
TAB_TTS_TIMING_LOG=/tmp/tab-tts-timings.jsonl

# To route the summary at a local Ollama (or any OpenAI-compatible endpoint),
# uncomment and set:
# TAB_TTS_SUMMARY_BASE_URL=http://localhost:11434/v1
# TAB_TTS_SUMMARY_MODEL=qwen2.5:7b
# (no key needed for localhost; for remote endpoints also set TAB_TTS_SUMMARY_KEY)

# Cross-event debounce window in seconds.
TAB_TTS_DEBOUNCE_SEC=2
